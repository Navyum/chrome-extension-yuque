22%3A37%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%22VALUE%22%2C%22x%22%3A71%2C%22y%22%3A29%2C%22width%22%3A34%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%22VALUE%22%2C%22x%22%3A596%2C%22y%22%3A28%2C%22width%22%3A34%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%22JERY%22%2C%22x%22%3A24%2C%22y%22%3A102%2C%22width%22%3A36%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22LCY%22%2C%22x%22%3A420%2C%22y%22%3A123%2C%22width%22%3A33%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%22BOB%22%2C%22x%22%3A26%2C%22y%22%3A53%2C%22width%22%3A26%2C%22height%22%3A14%7D%2C%7B%22text%22%3A%229000%22%2C%22x%22%3A469%2C%22y%22%3A124%2C%22width%22%3A35%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%221000%22%2C%22x%22%3A195%2C%22y%22%3A74%2C%22width%22%3A38%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%22LCY%22%2C%22x%22%3A22%2C%22y%22%3A146%2C%22width%22%3A32%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22ALICE%22%2C%22x%22%3A25%2C%22y%22%3A78%2C%22width%22%3A34%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%22VALUE%22%2C%22x%22%3A195%2C%22y%22%3A51%2C%22width%22%3A35%2C%22height%22%3A11%7D%2C%7B%22text%22%3A%22VALUE%22%2C%22x%22%3A468%2C%22y%22%3A52%2C%22width%22%3A36%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%22ERRY%22%2C%22x%22%3A544%2C%22y%22%3A145%2C%22width%22%3A35%2C%22height%22%3A15%7D%2C%7B%22text%22%3A%22KEU%22%2C%22x%22%3A421%2C%22y%22%3A52%2C%22width%22%3A28%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22BOB%22%2C%22x%22%3A549%2C%22y%22%3A52%2C%22width%22%3A28%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22KEU%22%2C%22x%22%3A549%2C%22y%22%3A28%2C%22width%22%3A27%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22A(ICE%22%2C%22x%22%3A547%2C%22y%22%3A122%2C%22width%22%3A31%2C%22height%22%3A16%7D%2C%7B%22text%22%3A%221000%22%2C%22x%22%3A468%2C%22y%22%3A75%2C%22width%22%3A39%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22BOB%22%2C%22x%22%3A147%2C%22y%22%3A73%2C%22width%22%3A29%2C%22height%22%3A15%7D%2C%7B%22text%22%3A%225000%22%2C%22x%22%3A72%2C%22y%22%3A125%2C%22width%22%3A32%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%225000%22%2C%22x%22%3A594%2C%22y%22%3A76%2C%22width%22%3A36%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%222000%22%2C%22x%22%3A591%2C%22y%22%3A146%2C%22width%22%3A39%2C%22height%22%3A11%7D%2C%7B%22text%22%3A%229000%22%2C%22x%22%3A593%2C%22y%22%3A101%2C%22width%22%3A37%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%22BOB%22%2C%22x%22%3A422%2C%22y%22%3A75%2C%22width%22%3A29%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22OW%22%2C%22x%22%3A25%2C%22y%22%3A125%2C%22width%22%3A28%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22KEU%22%2C%22x%22%3A148%2C%22y%22%3A50%2C%22width%22%3A27%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22TOM%22%2C%22x%22%3A423%2C%22y%22%3A99%2C%22width%22%3A27%2C%22height%22%3A14%7D%2C%7B%22text%22%3A%22TO%22%2C%22x%22%3A545%2C%22y%22%3A77%2C%22width%22%3A33%2C%22height%22%3A12%7D%2C%7B%22text%22%3A%22KEU%22%2C%22x%22%3A24%2C%22y%22%3A30%2C%22width%22%3A28%2C%22height%22%3A13%7D%2C%7B%22text%22%3A%22LCY%22%2C%22x%22%3A547%2C%22y%22%3A100%2C%22width%22%3A30%2C%22height%22%3A13%7D%5D%2C%22showTitle%22%3Afalse%2C%22title%22%3A%22%22%2C%22rotation%22%3A0%2C%22crop%22%3A%5B0%2C0%2C1%2C1%5D%2C%22averageHue%22%3A%22%23fdfdfc%22%2C%22id%22%3A%22u5a0cf59d%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D\&quot;"></card></p>
  <ul list="\&quot;u98526ca5\&quot;">
   <li fid="\&quot;u0723afd3\&quot;" data-lake-id="\&quot;u83254d5b\&quot;" id="\&quot;u83254d5b\&quot;"><span data-lake-id="\&quot;uee62d3af\&quot;" id="\&quot;uee62d3af\&quot;" style="\&quot;color:" rgb(53,="" 53,="" 53)\"="">注意：</span><span data-lake-id="\&quot;ued488e22\&quot;" id="\&quot;ued488e22\&quot;" style="\&quot;color:" rgb(76,="" 76,="" 76)\"="">适合集群节点数已知、少量、稳定的场景，主要由于反熵需要节点两两交换和比对自己所有的数据，执行反熵时</span><strong><span data-lake-id="\&quot;u13a3a6cc\&quot;" id="\&quot;u13a3a6cc\&quot;" style="\&quot;color:" rgb(76,="" 76,="" 76)\"="">通讯成本会很高</span></strong><span data-lake-id="\&quot;u318a6c26\&quot;" id="\&quot;u318a6c26\&quot;" style="\&quot;color:" rgb(76,="" 76,="" 76)\"="">，性能消耗高。</span><span data-lake-id="\&quot;u08f90336\&quot;" id="\&quot;u08f90336\&quot;" style="\&quot;color:" rgb(53,="" 53,="" 53)\"="">所以不建议在实际场景中频繁执行反熵，并且可以通过引入校验和（Checksum）等机制，降低需要对比的数据量和通讯消息等。</span></li>
   <li fid="\&quot;u0723afd3\&quot;" data-lake-id="\&quot;u36f02505\&quot;" id="\&quot;u36f02505\&quot;"><span data-lake-id="\&quot;uca50e5c0\&quot;" id="\&quot;uca50e5c0\&quot;" style="\&quot;color:" rgb(76,="" 76,="" 76)\"="">同时需要注意，实现反熵时一般设计一个</span><strong><span data-lake-id="\&quot;u2940b799\&quot;" id="\&quot;u2940b799\&quot;" style="\&quot;color:" rgb(76,="" 76,="" 76)\"="">闭环流程</span></strong><span data-lake-id="\&quot;u2aa85232\&quot;" id="\&quot;u2aa85232\&quot;" style="\&quot;color:" rgb(76,="" 76,="" 76)\"="">（闭环很重要！如下图案例），一次修复所有节点的副本数据不一致，因为我们希望能在</span><strong><span data-lake-id="\&quot;u8586b2e7\&quot;" id="\&quot;u8586b2e7\&quot;" style="\&quot;color:" rgb(76,="" 76,="" 76)\"="">一个确定的时间范围内实现数据副本的最终一致性</span></strong><span data-lake-id="\&quot;u44d4e281\&quot;" id="\&quot;u44d4e281\&quot;" style="\&quot;color:" rgb(76,="" 76,="" 76)\"="">，而不是基于随机性的概率，在一个不确定的时间范围内实现数据副本的最终一致性。</span></li>
  </ul>
  <p data-lake-id="\&quot;u8e4e4052\&quot;" id="\&quot;u8e4e4052\&quot;" style="\&quot;text-indent:" 2em\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;image\&quot;" value="\&quot;data:%7B%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F0%2F2024%2Fpng%2F34523858%2F1733662448348-d58e1ad0-7249-47ef-9ec9-61a6b3aeb117.png%22%2C%22taskId%22%3A%22u80b2be3a-0b91-4f96-b489-c5e73b95acb%22%2C%22clientId%22%3A%22u557dc0ce-6321-4%22%2C%22originalType%22%3A%22binary%22%2C%22width%22%3A557.5%2C%22height%22%3A367%2C%22linkTarget%22%3A%22_blank%22%2C%22name%22%3A%22image.png%22%2C%22size%22%3A187364%2C%22from%22%3A%22paste%22%2C%22originWidth%22%3A649%2C%22originHeight%22%3A427%2C%22ratio%22%3A2%2C%22status%22%3A%22done%22%2C%22style%22%3A%22stroke%22%2C%22ocrLocations%22%3A%5B%7B%22text%22%3A%22SHARD1%2CSHARD2%E7%BC%BA%E5%A4%B1%E7%9A%84%E6%95%B0%E6%8D%AE%22%2C%22x%22%3A12%2C%22y%22%3A192%2C%22width%22%3A195%2C%22height%22%3A15%7D%2C%7B%22text%22%3A%22SHARD1%2CSHARD2%E7%BC%BA%E5%A4%B1%E7%9A%84%E6%95%B0%E6%8D%AE%22%2C%22x%22%3A430%2C%22y%22%3A168%2C%22width%22%3A194%2C%22height%22%3A14%7D%2C%7B%22text%22%3A%221.%E5%AF%B9%E6%AF%94%E5%92%8C%E4%BF%AE%E5%A4%8D%E8%8A%82%E7%82%B9B%E4%B8%AD%22%2C%22x%22%3A433%2C%22y%22%3A146%2C%22width%22%3A148%2C%22height%22%3A16%7D%2C%7B%22text%22%3A%22SHARD1%2CSHARD2%E7%BC%BA%E5%A4%B1%E7%9A%84%E6%95%B0%E6%8D%AE%22%2C%22x%22%3A226%2C%22y%22%3A240%2C%22width%22%3A194%2C%22height%22%3A16%7D%2C%7B%22text%22%3A%22SHARD1%2CSHARD2%E7%BC%BA%E5%A4%B1%E7%9A%84%E6%95%B0%E6%8D%AE%22%2C%22x%22%3A222%2C%22y%22%3A373%2C%22width%22%3A190%2C%22height%22%3A16%7D%2C%7B%22text%22%3A%224.%E5%AF%B9%E6%AF%94%E5%92%8C%E4%BF%AE%E5%A4%8D%E8%8A%82%E7%82%B9B%E4%B8%AD%22%2C%22x%22%3A226%2C%22y%22%3A219%2C%22width%22%3A145%2C%22height%22%3A16%7D%2C%7B%22text%22%3A%223.%E5%AF%B9%E6%AF%94%E5%92%8C%E4%BF%AE%E5%A4%8D%E8%8A%82%E7%82%B9A%E4%B8%AD%22%2C%22x%22%3A14%2C%22y%22%3A171%2C%22width%22%3A143%2C%22height%22%3A15%7D%2C%7B%22text%22%3A%222.%E5%AF%B9%E6%AF%94%E5%92%8C%E4%BF%AE%E5%A4%8D%E8%8A%82%E7%82%B9C%E4%B8%AD%22%2C%22x%22%3A220%2C%22y%22%3A353%2C%22width%22%3A146%2C%22height%2