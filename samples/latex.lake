  <ol list="\&quot;ua2643bdf\&quot;">
   <li fid="\&quot;u82a30dba\&quot;" data-lake-id="\&quot;u1d7c2db9\&quot;" id="\&quot;u1d7c2db9\&quot;"><strong><span data-lake-id="\&quot;ue6bf1e54\&quot;" id="\&quot;ue6bf1e54\&quot;">矩阵的向量化</span></strong></li>
