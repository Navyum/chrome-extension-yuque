  </ol>
  <p data-lake-id="\&quot;u6f51de90\&quot;" id="\&quot;u6f51de90\&quot;"><span data-lake-id="\&quot;ucd560d48\&quot;" id="\&quot;ucd560d48\&quot;">矩阵</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%20%5C%5Cin%20%5C%5Cmathbb%7BR%7D%5E%7Bm%20%5C%5Ctimes%20n%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fa29eb9ee2111d8b446d60a4ff740a5dc.svg%22%2C%22id%22%3A%22djoXu%22%7D\&quot;"></card><span data-lake-id="\&quot;u4f35a72c\&quot;" id="\&quot;u4f35a72c\&quot;">和矩阵</span>
