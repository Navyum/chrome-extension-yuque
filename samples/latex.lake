  <p data-lake-id="\&quot;uf3eb1024\&quot;" id="\&quot;uf3eb1024\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22AI%20%3D%20%5C%5Cbegin%7Bbmatrix%7D%201%20%5C%5Ctimes%201%20%2B%202%20%5C%5Ctimes%200%20%26%201%20%5C%5Ctimes%200%20%2B%202%20%5C%5Ctimes%201%20%5C%5C%5C%5C%203%20%5C%5Ctimes%201%20%2B%205%20%5C%5Ctimes%200%20%26%203%20%5C%5Ctimes%200%20%2B%205%20%5C%5Ctimes%201%20%5C%5C%5C%5C%204%20%5C%5Ctimes%201%20%2B%208%20%5C%5Ctimes%200%20%26%204%20%5C%5Ctimes%200%20%2B%208%20%5C%5Ctimes%201%20%5C%5Cend%7Bbmatrix%7D%20%3D%20%5C%5Cbegin%7Bbmatrix%7D%201%20%26%202%20%5C%5C%5C%5C%203%20%26%205%20%5C%5C%5C%5C%204%20%26%208%20%5C%5Cend%7Bbmatrix%7D%20%3D%20A%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fa19a8308ca634e97ee9bdba2c4ebbbc3.svg%22%2C%22id%22%3A%22PGb6U%22%7D\&quot;"></card></p>
