  <p data-lake-id="\&quot;ub5bbe046\&quot;" id="\&quot;ub5bbe046\&quot;"><strong><span data-lake-id="\&quot;u74cd4407\&quot;" id="\&quot;u74cd4407\&quot;">矩阵乘法的性质</span></strong><span data-lake-id="\&quot;ue0dd0de8\&quot;" id="\&quot;ue0dd0de8\&quot;"><br /></span><span data-lake-id="\&quot;ufcf272dd\&quot;" id="\&quot;ufcf272dd\&quot;">矩阵乘法满足结合律、左分配律和右分配律。不满足交换律即</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22AB%20%5C%5Cneq%20BA%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F05fa7888aa17ed1b0d9d2a8a632201e5.svg%22%2C%22id%22%3A%22tuRVy%22%7D\&quot;"></card><span data-lake-id="\&quot;u4bda81d8\&quot;" id="\&quot;u4bda81d8\&quot;">。</span></p>
  <ul list="\&quot;u4b893308\&quot;">
   <li fid="\&quot;u5654059d\&quot;" data-lake-id="\&quot;u1171621a\&quot;" id="\&quot;u1171621a\&quot;"><span data-lake-id="\&quot;u60cdc3ef\&quot;" id="\&quot;u60cdc3ef\&quot;">结合律：若</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%20%5C%5Cin%20%5C%5Cmathbb%7BR%7D%5E%7Bm%20%5C%5Ctimes%20n%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fa29eb9ee2111d8b446d60a4ff740a5dc.svg%22%2C%22id%22%3A%22fkRmm%22%7D\&quot;"></card><span data-lake-id="\&quot;u3532a654\&quot;" id="\&quot;u3532a654\&quot;">，</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22B%20%5C%5Cin%20%5C%5Cmathbb%7BR%7D%5E%7Bn%20%5C%5Ctimes%20p%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F4e5ab2e79c358c31eadd032f2a6a0a57.svg%22%2C%22id%22%3A%22Wzx2Y%22%7D\&quot;"></card><span data-lake-id="\&quot;u25977eae\&quot;" id="\&quot;u25977eae\&quot;">，</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22C%20%5C%5Cin%20%5C%5Cmathbb%7BR%7D%5E%7Bp%20%5C%5Ctimes%20q%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F94f7824f0f9c0d2b6aedb574f0d5ba63.svg%22%2C%22id%22%3A%22cKUJ4%22%7D\&quot;"></card><span data-lake-id="\&quot;ub5ddcf1e\&quot;" id="\&quot;ub5ddcf1e\&quot;">，则</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22(AB)C%20%3D%20A(BC)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F80982eed7b9ac3be5eb8338c524cd0fe.svg%22%2C%22id%22%3A%22MeLYU%22%7D\&quot;"></card><span data-lake-id="\&quot;u5192019d\&quot;" id="\&quot;u5192019d\&quot;">​</span></li>
   <li fid="\&quot;u5654059d\&quot;" data-lake-id="\&quot;uadaf763a\&quot;" id="\&quot;uadaf763a\&quot;"><span data-lake-id="\&quot;u1da822c4\&quot;" id="\&quot;u1da822c4\&quot;">左分配律：若</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%20%5C%5Cin%20%5C%5Cmathbb%7BR%7D%5E%7Bm%20%5C%5Ctimes%20n%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fa29eb9ee2111d8b446d60a4ff740a5dc.svg%22%2C%22id%22%3A%22ybmXN%22%7D\&quot;"></card><span data-lake-id="\&quot;ua17f8376\&quot;" id="\&quot;ua17f8376\&quot;">，</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22B%2C%20C%20%5C%5Cin%20%5C%5Cmathbb%7BR%7D%5E%7Bn%20%5C%5Ctimes%20p%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Ffe34ae1a58e42cc1875beb279d74189a.svg%22%2C%22id%22%3A%22ZrVPa%22%7D\&quot;"></card><span data-lake-id="\&quot;u9662fd00\&quot;" id="\&quot;u9662fd00\&quot;">，则</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A(B%20%2B%20C)%20%3D%20AB%20%2B%20AC%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F47c82dfabb5fa63e98adfb037491ee2f.svg%22%2C%22id%22%3A%22SATnD%22%7D\&quot;"></card><span data-lake-id="\&quot;ua3071c8f\&quot;" id="\&quot;ua3071c8f\&quot;">​</span></li>
   <li fid="\&quot;u5654059d\&quot;" data-lake-id="\&quot;uff6cdb71\&quot;" id="\&quot;uff6cdb71\&quot;"><span data-lake-id="\&quot;u104fba2c\&quot;" id="\&quot;u104fba2c\&quot;">右分配律：若</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%2C%20B%20%5C%5Cin%20%5C%5Cmathbb%7BR%7D%5E%7Bm%20%5C%5Ctimes%20n%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F5c693e58c8f2173a2895e713ec5af6fc.svg%22%2C%22id%22%3A%22RBdbe%22%7D\&quot;"></card><span data-lake-id="\&quot;udd9d9608\&quot;" id="\&quot;udd9d9608\&quot;">，</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22C%20%5C%5Cin%20%5C%5Cmathbb%7BR%7D%5E%7Bn%20%5C%5Ctimes%20p%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fd771b65182d2a8f5af2e5d7dac5fe726.svg%22%2C%22id%22%3A%22gcmGW%22%7D\&quot;"></card><span data-lake-id="\&quot;u8014e556\&quot;" id="\&quot;u8014e556\&quot;">，则</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22(A%20%2B%20B)C%20%3D%20AC%20%2B%20BC%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F66a0b8eda9b4f2ba8a254ec48f83ca25.svg%22%2C%22id%22%3A%22R9tXo%22%7D\&quot;"></card></li>
  </ul>
