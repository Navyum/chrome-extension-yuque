  <p data-lake-id="\&quot;u35f25016\&quot;" id="\&quot;u35f25016\&quot;"><span data-lake-id="\&quot;u7efdc50f\&quot;" id="\&quot;u7efdc50f\&quot;">根据全微分公式，上式可以表示为：</span></p>
  <p data-lake-id="\&quot;u5aacf475\&quot;" id="\&quot;u5aacf475\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20l%7D(x_0%2C%20y_0)%20%3D%20f_x(x_0%2C%20y_0)%20%5C%5Ccos%20%5C%5Calpha%20%2B%20f_y(x_0%2C%20y_0)%20%5C%5Ccos%20%5C%5Cbeta%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fd77d01cdf4e4bc38981315e6e03a62db.svg%22%2C%22id%22%3A%22HEo09%22%7D\&quot;"></card></p>
  <p data-lake-id="\&quot;u01b6d8e2\&quot;" id="\&quot;u01b6d8e2\&quot;"><span data-lake-id="\&quot;u6636b8c9\&quot;" id="\&quot;u6636b8c9\&quot;">其中</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22f_x(x_0%2C%20y_0)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F8add1d1f0c29be20e1f08df0080f3eb5.svg%22%2C%22id%22%3A%22E5R4U%22%7D\&quot;"></card><span data-lake-id="\&quot;u9c5fabad\&quot;" id="\&quot;u9c5fabad\&quot;">、</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22f_y(x_0%2C%20y_0)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F6225855e41acd6a6adedb4fba18fdf50.svg%22%2C%22id%22%3A%22ENXdD%22%7D\&quot;"></card><span data-lake-id="\&quot;u68395c65\&quot;" id="\&quot;u68395c65\&quot;">表示点</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22(x_0%2C%20y_0)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F722e68ed71eb4284ecd12ffaa8d8d860.svg%22%2C%22id%22%3A%22KFllP%22%7D\&quot;"></card><span data-lake-id="\&quot;ufa9f7a5a\&quot;" id="\&quot;ufa9f7a5a\&quot;">处</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22f%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F18f3c2855f0e85a1ac2257f64d917144.svg%22%2C%22id%22%3A%22hdpUV%22%7D\&quot;"></card><span data-lake-id="\&quot;u036d3b19\&quot;" id="\&quot;u036d3b19\&quot;">对</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22x%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F712ecf7894348e92d8779c3ee87eeeb0.svg%22%2C%22id%22%3A%22DfLBE%22%7D\&quot;"></card><span data-lake-id="\&quot;u2fbeb0b0\&quot;" id="\&quot;u2fbeb0b0\&quot;">、</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22y%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fbf98c0ddcbe9c1e535f767c78c3aa813.svg%22%2C%22id%22%3A%22okJFE%22%7D\&quot;"></card><span data-lake-id="\&quot;ud61ea638\&quot;" id="\&quot;ud61ea638\&quot;">的偏导数；</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Ccos%20%5C%5Calpha%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F5774599acd50b353d8ab2e86bc5e1f0c.svg%22%2C%22id%22%3A%22VwnLQ%22%7D\&quot;"></card><span data-lake-id="\&quot;u2d4adec3\&quot;" id="\&quot;u2d4adec3\&quot;">、</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Ccos%20%5C%5Cbeta%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F77ca74b125fd8432af7b4d77fc085cf8.svg%22%2C%22id%22%3A%22KxAih%22%7D\&quot;"></card><span data-lake-id="\&quot;ucd2d5d31\&quot;" id="\&quot;ucd2d5d31\&quot;">是方向</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22l%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F6945e109777fe3fd777e8254f0ec0f0c.svg%22%2C%22id%22%3A%22H8umO%22%7D\&quot;"></card><span data-lake-id="\&quot;u4de9ac4b\&quot;" id="\&quot;u4de9ac4b\&quot;">的方向余弦，即</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22l%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F6945e109777fe3fd777e8254f0ec0f0c.svg%22%2C%22id%22%3A%22zwXmY%22%7D\&quot;"></card><span data-lake-id="\&quot;ua85b04a9\&quot;" id="\&quot;ua85b04a9\&quot;">方向的单位方向向量可以表示为</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cmathbf%7Bl%7D_0%20%3D%20(%5C%5Ccos%20%5C%5Calpha%2C%20%5C%5Ccos%20%5C%5Cbeta)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F279b1d1b597a62dcb9e777a77af4e787.svg%22%2C%22id%22%3A%22ykXNR%22%7D\&quot;"></card><span data-lake-id="\&quot;uc8645b29\&quot;" id="\&quot;uc8645b29\&quot;">。</span></p>
  <p data-lake-id="\&quot;u404e6e90\&quot;" id="\&quot;u404e6e90\&quot;"><span data-lake-id="\&quot;ub73d0c3f\&quot;" id="\&quot;ub73d0c3f\&quot;">这个&quot;沿某个方向的变化率&quot;，就被称为沿方向</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22l%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F6945e109777fe3fd777e8254f0ec0f0c.svg%22%2C%22id%22%3A%22r1ha2%22%7D\&quot;"></card><span data-lake-id="\&quot;u85daaba1\&quot;" id="\&quot;u85daaba1\&quot;">的</span><strong><span data-lake-id="\&quot;u56a60cb9\&quot;" id="\&quot;u56a60cb9\&quot;">方向导数</span></strong><span data-lake-id="\&quot;u46d4e352\&quot;" id="\&quot;u46d4e352\&quot;">。</span></p>
  <p data-lake-id="\&quot;ub1e3f51a\&quot;" id="\&quot;ub1e3f51a\&quot;"><span data-lake-id="\&quot;u93cb0260\&quot;" id="\&quot;u93cb0260\&quot;">​</span><br /></p>
  <h4 data-lake-id="\&quot;cK6kv\&quot;" id="\&quot;cK6kv\&quot;"><span data-lake-id="\&quot;u317f35c7\&quot;" id="\&quot;u317f35c7\&quot;">梯度</span></h4>
  <p data-lake-id="\&quot;u9faa0334\&quot;" id="\&quot;u9faa0334\&quot;"><span data-lake-id="\&quot;uc8af9e26\&quot;" id="\&quot;uc8af9e26\&quot;">对于多元函数</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22f(x_1%2C%20x_2%2C%20%5C%5Cldots%2C%20x_n)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fbaadbc61251602bdf6189471283487e4.svg%22%2C%22id%22%3A%22goKWu%22%7D\&quot;"></card><span data-lake-id="\&quot;u25f50dcb\&quot;" id="\&quot;u25f50dcb\&quot;">，如果它在点</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cmathbf%7Ba%7D%20%3D%20(a_1%2C%20a_2%2C%20%5C%5Cldots%2C%20a_n)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F19102a2e4c178269fef8cc0eeac1c750.svg%22%2C%22id%22%3A%22dIyBC%22%7D\&quot;"></card><span data-lake-id="\&quot;uae4318b3\&quot;" id="\&quot;uae4318b3\&quot;">处关于每个变量</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22x_i%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F5b13ed0ae41bee9defcf75f2efc5f060.svg%22%2C%22id%22%3A%22GqYEF%22%7D\&quot;"></card><span data-lake-id="\&quot;u6526987c\&quot;" id="\&quot;u6526987c\&quot;">都有偏导数</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_i%7D(%5C%5Cmathbf%7Ba%7D)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F3dedd80869a6db19efffc21a44b70b0e.svg%22%2C%22id%22%3A%22VmpgE%22%7D\&quot;"></card><span data-lake-id="\&quot;u6eb2e683\&quot;" id="\&quot;u6eb2e683\&quot;">，那么这些偏导数定义出一个向量：</span></p>
  <p data-lake-id="\&quot;u2905bad2\&quot;" id="\&quot;u2905bad2\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cnabla%20f(%5C%5Cmathbf%7Ba%7D)%20%3D%20%5C%5Cleft%5B%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_1%7D(%5C%5Cmathbf%7Ba%7D)%2C%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_2%7D(%5C%5Cmathbf%7Ba%7D)%2C%20%5C%5Cldots%2C%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_n%7D(%5C%5Cmathbf%7Ba%7D)%5C%5Cright%5D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F532e6faa7fc9c153d999b4a2bba6703a.svg%22%2C%22id%22%3A%22cxMOm%22%7D\&quot;"></card></p>
  <p data-lake-id="\&quot;ud4e7ea3c\&quot;" id="\&quot;ud4e7ea3c\&quot;"><span data-lake-id="\&quot;u3ac6f0cb\&quot;" id="\&quot;u3ac6f0cb\&quot;">这个向量称为在点</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cmathbf%7Ba%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F2097518d227bec7bfc7b6d82278fdba1.svg%22%2C%22id%22%3A%22MWgAu%22%7D\&quot;"></card><span data-lake-id="\&quot;u104da0b2\&quot;" id="\&quot;u104da0b2\&quot;">的</span><strong><span data-lake-id="\&quot;u5aec33eb\&quot;" id="\&quot;u5aec33eb\&quot;">梯度</span></strong><span data-lake-id="\&quot;u9b4299be\&quot;" id="\&quot;u9b4299be\&quot;">，记作</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cnabla%20f(%5C%5Cmathbf%7Ba%7D)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F840cc2c9ec8b076efe51cc1b6afd60bc.svg%22%2C%22id%22%3A%22kP8b0%22%7D\&quot;"></card><span data-lake-id="\&quot;u259d1982\&quot;" id="\&quot;u259d1982\&quot;">或者</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Ctext%7Bgrad%20%7D%20f(%5C%5Cmathbf%7Ba%7D)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F91326b8e406ff8e96d44bfbcc4c02654.svg%22%2C%22id%22%3A%22YwDwz%22%7D\&quot;"></card><span data-lake-id="\&quot;u303304bb\&quot;" id="\&quot;u303304bb\&quot;">。</span></p>
  <p data-lake-id="\&quot;u89e2868a\&quot;" id="\&quot;u89e2868a\&quot;"><span data-lake-id="\&quot;u8b574c86\&quot;" id="\&quot;u8b574c86\&quot;">例如：</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22f(x%2C%20y)%20%3D%20x%5E2%20%2B%20xy%20%2B%20y%5E2%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F16a992c93d04786d9afa27b8ac34d97b.svg%22%2C%22id%22%3A%22V9T81%22%7D\&quot;"></card><span data-lake-id="\&quot;uca3eaf0f\&quot;" id="\&quot;uca3eaf0f\&quot;">在</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22(1%2C%201)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F4d5c46172717f9c75409f196ca80cf90.svg%22%2C%22id%22%3A%22egqJB%22%7D\&quot;"></card><span data-lake-id="\&quot;u27b084aa\&quot;" id="\&quot;u27b084aa\&quot;">处的梯度为</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cnabla%20f(1%2C%201)%20%3D%20%5B3%2C%203%5D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F46d65640a9c8be4fa380f7868ead1871.svg%22%2C%22id%22%3A%22awbZz%22%7D\&quot;"></card><span data-lake-id="\&quot;u9fecbc8b\&quot;" id="\&quot;u9fecbc8b\&quot;">。</span></p>
  <p data-lake-id="\&quot;uca83e434\&quot;" id="\&quot;uca83e434\&quot;">
   <card type="\&quot;inline\&quot;" name="\&quot;image\&quot;" value="\&quot;data:%7B%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F0%2F2025%2Fpng%2F34523858%2F1766720611628-bbdeaaf2-7e8f-40b7-ae02-be2c759e1f80.png%22%2C%22taskId%22%3A%22ufbe361c3-4f56-4803-b004-aab805fe570%22%2C%22clientId%22%3A%22u91a152d8-9fbb-4%22%2C%22originalType%22%3A%22binary%22%2C%22width%22%3A405.6%2C%22height%22%3A341%2C%22linkTarget%22%3A%22_blank%22%2C%22name%22%3A%22image.png%22%2C%22size%22%3A865828%2C%22from%22%3A%22paste%22%2C%22originWidth%22%3A507%2C%22originHeight%22%3A426%2C%22ratio%22%3A1.25%2C%22status%22%3A%22done%22%2C%22style%22%3A%22stroke%22%2C%22search%22%3A%2280%2009%20F(X%2CY)%2040%2020%200%204%202%20-4%20-2%20-2%200%20-4%202%20X%204%22%2C%22ocrLocations%22%3A%5B%7B%22x%22%3A441%2C%22y%22%3A61%2C%22width%22%3A22%2C%22height%22%3A16%2C%22text%22%3A%2280%22%7D%2C%7B%22x%22%3A439%2C%22y%22%3A107%2C%22width%22%3A23%2C%22height%22%3A16%2C%22text%22%3A%2209%22%7D%2C%7B%22x%22%3A472%2C%22y%22%3A129%2C%22width%22%3A23%2C%22height%22%3A52%2C%22text%22%3A%22F(X%2CY)%22%7D%2C%7B%22x%22%3A439%2C%22y%22%3A153%2C%22width%22%3A20%2C%22height%22%3A16%2C%22text%22%3A%2240%22%7D%2C%7B%22x%22%3A435%2C%22y%22%3A197%2C%22width%22%3A22%2C%22height%22%3A16%2C%22text%22%3A%2220%22%7D%2C%7B%22x%22%3A437%2C%22y%22%3A241%2C%22width%22%3A13%2C%22height%22%3A18%2C%22text%22%3A%220%22%7D%2C%7B%22x%22%3A409%2C%22y%22%3A296%2C%22width%22%3A14%2C%22height%22%3A16%2C%22text%22%3A%224%22%7D%2C%7B%22x%22%3A387%2C%22y%22%3A318%2C%22width%22%3A14%2C%22height%22%3A17%2C%22text%22%3A%222%22%7D%2C%7B%22x%22%3A36%2C%22y%22%3A352%2C%22width%22%3A25%2C%22height%22%3A14%2C%22text%22%3A%22-4%22%7D%2C%7B%22x%22%3A82%2C%22y%22%3A362%2C%22width%22%3A23%2C%22height%22%3A17%2C%22text%22%3A%22-2%22%7D%2C%7B%22x%22%3A339%2C%22y%22%3A363%2C%22width%22%3A26%2C%22height%22%3A16%2C%22text%22%3A%22-2%22%7D%2C%7B%22x%22%3A130%2C%22y%22%3A374%2C%22width%22%3A15%2C%22height%22%3A18%2C%22text%22%3A%220%22%7D%2C%7B%22x%22%3A315%2C%22y%22%3A386%2C%22width%22%3A26%2C%22height%22%3A16%2C%22text%22%3A%22-4%22%7D%2C%7B%22x%22%3A176%2C%22y%22%3A386%2C%22width%22%3A13%2C%22height%22%3A20%2C%22text%22%3A%222%22%7D%2C%7B%22x%22%3A114%2C%22y%22%3A398%2C%22width%22%3A16%2C%22height%22%3A18%2C%22text%22%3A%22X%22%7D%2C%7B%22x%22%3A224%2C%22y%22%3A402%2C%22width%22%3A12%2C%22height%22%3A15%2C%22text%22%3A%224%22%7D%5D%2C%22showTitle%22%3Afalse%2C%22title%22%3A%22%22%2C%22rotation%22%3A0%2C%22crop%22%3A%5B0%2C0%2C1%2C1%5D%2C%22averageHue%22%3A%22%23f3f3f3%22%2C%22id%22%3A%22uaeb5db1d%22%7D\&quot;"></card></p>
  <p data-lake-id="\&quot;uc68ca9ba\&quot;" id="\&quot;uc68ca9ba\&quot;"><span data-lake-id="\&quot;u0195522d\&quot;" id="\&quot;u0195522d\&quot;">梯度向量表示的方向，就是函数在这一点处，方向导数取最大值的方向。换句话说，梯度的方向，就是函数值变化最快的方向。</span></p>
  <p data-lake-id="\&quot;u723dfd8a\&quot;" id="\&quot;u723dfd8a\&quot;"><span data-lake-id="\&quot;ue8f64047\&quot;" id="\&quot;ue8f64047\&quot;">​</span><br /></p>
  <h2 data-lake-id="\&quot;V3kwj\&quot;" id="\&quot;V3kwj\&quot;"><span data-lake-id="\&quot;u738a7860\&quot;" id="\&quot;u738a7860\&quot;">线性代数</span></h2>
  <h3 data-lake-id="\&quot;UIfLf\&quot;" id="\&quot;UIfLf\&quot;"><span data-lake-id="\&quot;u350455e2\&quot;" id="\&quot;u350455e2\&quot;">标量与向量</span></h3>
  <h4 data-lake-id="\&quot;fXUEy\&quot;" id="\&quot;fXUEy\&quot;"><span data-lake-id="\&quot;uad2c0f83\&quot;" id="\&quot;uad2c0f83\&quot;">标量与向量的概念</span></h4>
  <p data-lake-id="\&quot;ud763d304\&quot;" id="\&quot;ud763d304\&quot;"><strong><span data-lake-id="\&quot;u5c19fd4a\&quot;" id="\&quot;u5c19fd4a\&quot;">标量（scalar）</span></strong><span data-lake-id="\&quot;u20385f21\&quot;" id="\&quot;u20385f21\&quot;">：标量是一个单独的数，只有大小。<br /></span><strong><span data-lake-id="\&quot;u8b7d87b2\&quot;" id="\&quot;u8b7d87b2\&quot;">向量</span></strong><span data-lake-id="\&quot;uaffa8cc4\&quot;" id="\&quot;uaffa8cc4\&quot;">（vector）：向量由标量组成，有大小有方向。</span></p>
  <ul list="\&quot;ue1a2088d\&quot;">
   <li fid="\&quot;ub2cc1556\&quot;" data-lake-id="\&quot;uee751df9\&quot;" id="\&quot;uee751df9\&quot;"><strong><span data-lake-id="\&quot;u55daafce\&quot;" id="\&quot;u55daafce\&quot;">行向量</span></strong><span data-lake-id="\&quot;u8858642b\&quot;" id="\&quot;u8858642b\&quot;">：</span></li>
  </ul>
  <p data-lake-id="\&quot;u50109364\&quot;" id="\&quot;u50109364\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cmathbf%7Bx%7D%5ET%20%3D%20%5Bx_1%2C%20x_2%2C%20%5C%5Cldots%2C%20x_n%5D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fcaaa6df0f958f84833f0ca55fa764680.svg%22%2C%22id%22%3A%22uGZaR%22%7D\&quot;"></card></p>
  <ul list="\&quot;u564d489a\&quot;">
   <li fid="\&quot;ubb78bae8\&quot;" data-lake-id="\&quot;u9e848204\&quot;" id="\&quot;u9e848204\&quot;"><strong><span data-lake-id="\&quot;uda31be1a\&quot;" id="\&quot;uda31be1a\&quot;">列向量</span></strong><span data-lake-id="\&quot;u5c1f42ea\&quot;" id="\&quot;u5c1f42ea\&quot;">：</span></li>
  </ul>
  <p data-lake-id="\&quot;u8c267689\&quot;" id="\&quot;u8c267689\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cmathbf%7Bx%7D%20%3D%20%5C%5Cbegin%7Bbmatrix%7D%20x_1%20%5C%5C%5C%5C%20x_2%20%5C%5C%5C%5C%20%5C%5Cvdots%20%5C%5C%5C%5C%20x_n%20%5C%5Cend%7Bbmatrix%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fd8194ae61a2af665d2c381f6bf07131a.svg%22%2C%22id%22%3A%22n37pg%22%7D\&quot;"></card></p>
  <p data-lake-id="\&quot;u14547421\&quot;" id="\&quot;u14547421\&quot;"><br /></p>
  <h4 data-lake-id="\&quot;r4NVi\&quot;" id="\&quot;r4NVi\&quot;"><span data-lake-id="\&quot;u096a614e\&quot;" id="\&quot;u096a614e\&quot;">向量运算</span></h4>
  <ol list="\&quot;u5359a4ee\&quot;">
   <li fid="\&quot;u31049c1c\&quot;" data-lake-id="\&quot;u6c5046bf\&quot;" id="\&quot;u6c5046bf\&quot;"><span data-lake-id="\&quot;ub1f36d13\&quot;" id="\&quot;ub1f36d13\&quot;">向量转置：列向量转置结果为行向量</span></li>
  </ol>
  <p data-lake-id="\&quot;uc916ae0d\&quot;" id="\&quot;uc916ae0d\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cmathbf%7Bx%7D%20%3D%20%5C%5Cbegin%7Bbmatrix%7D%20x_1%20%5C%5C%5C%5C%20x_2%20%5C%5C%5C%5C%20%5C%5Cvdots%20%5C%5C%5C%5C%20x_n%20%5C%5Cend%7Bbmatrix%7D%2C%20%5C%5Cquad%20%5C%5Cmathbf%7Bx%7D%5ET%20%3D%20%5Bx_1%2C%20x_2%2C%20%5C%5Cldots%2C%20x_n%5D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F671bbb6f08474758f5670605506e6ae5.svg%22%2C%22id%22%3A%22xwkub%22%7D\&quot;"></card></p>
  <ol list="\&quot;u68665f32\&quot;" start="\&quot;2\&quot;">
   <li fid="\&quot;u9c64bfc1\&quot;" data-lake-id="\&quot;u05d55aa3\&quot;" id="\&quot;u05d55aa3\&quot;"><span data-lake-id="\&quot;uea9f9d41\&quot;" id="\&quot;uea9f9d41\&quot;">向量相加：对应元素相加</span></li>
  </ol>
  <p data-lake-id="\&quot;u59a4a22a\&quot;" id="\&quot;u59a4a22a\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cmathbf%7Bx%7D%20%2B%20%5C%5Cmathbf%7By%7D%20%3D%20%5Bx_1%20%2B%20y_1%2C%20x_2%20%2B%20y_2%2C%20%5C%5Cldots%2C%20x_n%20%2B%20y_n%5D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F838571c6fa26b1fb1032df6fe424d40a.svg%22%2C%22id%22%3A%22pihXt%22%7D\&quot;"></card></p>
