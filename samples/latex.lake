  <h4 data-lake-id="\&quot;KNg6A\&quot;" id="\&quot;KNg6A\&quot;"><span data-lake-id="\&quot;u21ccdf74\&quot;" id="\&quot;u21ccdf74\&quot;">矩阵转置</span></h4>
  <p data-lake-id="\&quot;u88dffa04\&quot;" id="\&quot;u88dffa04\&quot;"><strong><span data-lake-id="\&quot;uddd21977\&quot;" id="\&quot;uddd21977\&quot;">矩阵转置运算</span></strong></p>
  <p data-lake-id="\&quot;udaf1a93d\&quot;" id="\&quot;udaf1a93d\&quot;"><span data-lake-id="\&quot;u0f141b47\&quot;" id="\&quot;u0f141b47\&quot;">矩阵</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%20%5C%5Cin%20%5C%5Cmathbb%7BR%7D%5E%7Bm%20%5C%5Ctimes%20n%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fa29eb9ee2111d8b446d60a4ff740a5dc.svg%22%2C%22id%22%3A%22XmFH4%22%7D\&quot;"></card><span data-lake-id="\&quot;u3b732b2f\&quot;" id="\&quot;u3b732b2f\&quot;">的转置是一个</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22n%20%5C%5Ctimes%20m%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Faa6a494674a94b16c26c0e18d47d80d2.svg%22%2C%22id%22%3A%22aR8Sk%22%7D\&quot;"></card><span data-lake-id="\&quot;ue7d02be9\&quot;" id="\&quot;ue7d02be9\&quot;">的矩阵，记为</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%5ET%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fd9a5bd1a43baf1e5175841ce36e9a082.svg%22%2C%22id%22%3A%22ejm0h%22%7D\&quot;"></card><span data-lake-id="\&quot;u8e6357b9\&quot;" id="\&quot;u8e6357b9\&quot;">。其中</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%5ET%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fd9a5bd1a43baf1e5175841ce36e9a082.svg%22%2C%22id%22%3A%22I98jv%22%7D\&quot;"></card><span data-lake-id="\&quot;udcaaac19\&quot;" id="\&quot;udcaaac19\&quot;">的第</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22i%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F2443fbcfeb7e85e1d62b6f5e4f27207e.svg%22%2C%22id%22%3A%22mVbJN%22%7D\&quot;"></card><span data-lake-id="\&quot;u58305bc5\&quot;" id="\&quot;u58305bc5\&quot;">个行向量是原矩阵</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fde951302f41d4707b9d80ca1af34dd0f.svg%22%2C%22id%22%3A%22cY2JJ%22%7D\&quot;"></card><span data-lake-id="\&quot;uff40f087\&quot;" id="\&quot;uff40f087\&quot;">的第</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22i%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F2443fbcfeb7e85e1d62b6f5e4f27207e.svg%22%2C%22id%22%3A%22Bfl48%22%7D\&quot;"></card><span data-lake-id="\&quot;ue6a51f3c\&quot;" id="\&quot;ue6a51f3c\&quot;">个列向量；或者说，转置矩阵</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%5ET%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fd9a5bd1a43baf1e5175841ce36e9a082.svg%22%2C%22id%22%3A%22cmRX8%22%7D\&quot;"></card><span data-lake-id="\&quot;u474e71d5\&quot;" id="\&quot;u474e71d5\&quot;">第</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22i%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F2443fbcfeb7e85e1d62b6f5e4f27207e.svg%22%2C%22id%22%3A%22ztXgc%22%7D\&quot;"></card><span data-lake-id="\&quot;ucd4643a1\&quot;" id="\&quot;ucd4643a1\&quot;">行第</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22j%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F036441a335dd85c838f76d63a3db2363.svg%22%2C%22id%22%3A%22nyiYG%22%7D\&quot;"></card><span data-lake-id="\&quot;u26e1d84d\&quot;" id="\&quot;u26e1d84d\&quot;">列的元素是原矩阵</span>
