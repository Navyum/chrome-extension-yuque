     <td data-lake-id="\&quot;ucb6315e5\&quot;" id="\&quot;ucb6315e5\&quot;"><p data-lake-id="\&quot;u15f77d20\&quot;" id="\&quot;u15f77d20\&quot;">
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cfrac%7B%5C%5Cpartial%20(%5C%5Cmathbf%7Ba%7D%5ET%20X%20X%5ET%20%5C%5Cmathbf%7Bb%7D)%7D%7B%5C%5Cpartial%20X%7D%20%3D%20%5C%5Cmathbf%7Ba%7D%5C%5Cmathbf%7Bb%7D%5ET%20X%20%2B%20%5C%5Cmathbf%7Bb%7D%5C%5Cmathbf%7Ba%7D%5ET%20X%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F957fc86575f55e80f75d1ee79a0d60ac.svg%22%2C%22id%22%3A%22uHR5G%22%7D\&quot;"></card></p></td>
    </tr>
    <tr data-lake-id="\&quot;u615c4cfd\&quot;" id="\&quot;u615c4cfd\&quot;">
     <td data-lake-id="\&quot;uabd044a8\&quot;" id="\&quot;uabd044a8\&quot;"><p data-lake-id="\&quot;u22a089f5\&quot;" id="\&quot;u22a089f5\&quot;"><strong><span data-lake-id="\&quot;ue0e5701c\&quot;" id="\&quot;ue0e5701c\&quot;">标量对矩阵</span></strong></p></td>
     <td data-lake-id="\&quot;u7d16a6bb\&quot;" id="\&quot;u7d16a6bb\&quot;"><p data-lake-id="\&quot;uc5965829\&quot;" id="\&quot;uc5965829\&quot;">
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cfrac%7B%5C%5Cpartial%20(%5C%5Cmathbf%7Ba%7D%5ET%20X%5ET%20X%20%5C%5Cmathbf%7Bb%7D)%7D%7B%5C%5Cpartial%20X%7D%20%3D%20X%5C%5Cmathbf%7Bb%7D%5C%5Cmathbf%7Ba%7D%5ET%20%2B%20X%5C%5Cmathbf%7Ba%7D%5C%5Cmathbf%7Bb%7D%5ET%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fd3f39127b9d26b6df8f046fb86d318ab.svg%22%2C%22id%22%3A%22jRHNx%22%7D\&quot;"></card></p></td>
    </tr>
   </tbody>
  </table>
  <p data-lake-id="\&quot;u2847784f\&quot;" id="\&quot;u2847784f\&quot;"><br /></p>
  <h4 data-lake-id="\&quot;QHTdm\&quot;" id="\&quot;QHTdm\&quot;"><span data-lake-id="\&quot;u6c24b36f\&quot;" id="\&quot;u6c24b36f\&quot;">梯度矩阵</span></h4>
  <p data-lake-id="\&quot;u019c678d\&quot;" id="\&quot;u019c678d\&quot;"><span data-lake-id="\&quot;u81b50ef4\&quot;" id="\&quot;u81b50ef4\&quot;"> 梯度是</span><strong><span data-lake-id="\&quot;uf8cb52aa\&quot;" id="\&quot;uf8cb52aa\&quot;">各个维度上偏导矢量构成的向量和，方向就是该点最大的变化方向。</span></strong></p>
  <p data-lake-id="\&quot;uf4baee46\&quot;" id="\&quot;uf4baee46\&quot;"><span data-lake-id="\&quot;u7d07a08a\&quot;" id="\&quot;u7d07a08a\&quot;">对于实向量变元</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cmathbf%7Bx%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F2adf48e1cf80858f0604d2b51eeed4b8.svg%22%2C%22id%22%3A%22m7Okp%22%7D\&quot;"></card><span data-lake-id="\&quot;ub750be7c\&quot;" id="\&quot;ub750be7c\&quot;">，实标量函数</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22f(%5C%5Cmathbf%7Bx%7D)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fd1fed5d79d625df8f8cc788edf0f0328.svg%22%2C%22id%22%3A%22vUg6L%22%7D\&quot;"></card><span data-lake-id="\&quot;uc1ec6965\&quot;" id="\&quot;uc1ec6965\&quot;">的梯度向量，为</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cmathbf%7Bx%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F2adf48e1cf80858f0604d2b51eeed4b8.svg%22%2C%22id%22%3A%22fRZ6b%22%7D\&quot;"></card><span data-lake-id="\&quot;u4678460f\&quot;" id="\&quot;u4678460f\&quot;">的列向量（与</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cmathbf%7Bx%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F2adf48e1cf80858f0604d2b51eeed4b8.svg%22%2C%22id%22%3A%22BSHAs%22%7D\&quot;"></card><span data-lake-id="\&quot;ucc9f215e\&quot;" id="\&quot;ucc9f215e\&quot;">形状相同）：</span></p>
  <p data-lake-id="\&quot;u005b47be\&quot;" id="\&quot;u005b47be\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cnabla%20f(%5C%5Cmathbf%7Bx%7D)%20%3D%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20%5C%5Cmathbf%7Bx%7D%7D%20%3D%20%5C%5Cbegin%7Bbmatrix%7D%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_1%7D%20%5C%5C%5C%5C%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_2%7D%20%5C%5C%5C%5C%20%5C%5Cvdots%20%5C%5C%5C%5C%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_n%7D%20%5C%5Cend%7Bbmatrix%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F22962056e2e6a7188a511e5e469bcb36.svg%22%2C%22id%22%3A%22wWqE2%22%7D\&quot;"></card></p>
  <p data-lake-id="\&quot;u5dc8fbba\&quot;" id="\&quot;u5dc8fbba\&quot;"><span data-lake-id="\&quot;uae9dd47e\&quot;" id="\&quot;uae9dd47e\&quot;">对于矩阵变元</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22X%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F94e79ad0c1aabeafef9e2fc4af6adf66.svg%22%2C%22id%22%3A%22uj5ch%22%7D\&quot;"></card><span data-lake-id="\&quot;ubcb785cb\&quot;" id="\&quot;ubcb785cb\&quot;">，可以类似地得到</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22f(X)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F2d2090d63bb343fd9cb4f3bd431dda0e.svg%22%2C%22id%22%3A%22WbIdC%22%7D\&quot;"></card><span data-lake-id="\&quot;u5fe3112c\&quot;" id="\&quot;u5fe3112c\&quot;">的梯度矩阵：</span></p>
  <p data-lake-id="\&quot;u86decfae\&quot;" id="\&quot;u86decfae\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5Cnabla%20f(X)%20%3D%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20X%7D%20%3D%20%5C%5Cbegin%7Bbmatrix%7D%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_%7B11%7D%7D%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_%7B12%7D%7D%20%26%20%5C%5Ccdots%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_%7B1n%7D%7D%20%5C%5C%5C%5C%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_%7B21%7D%7D%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_%7B22%7D%7D%20%26%20%5C%5Ccdots%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_%7B2n%7D%7D%20%5C%5C%5C%5C%20%5C%5Cvdots%20%26%20%5C%5Cvdots%20%26%20%5C%5Cddots%20%26%20%5C%5Cvdots%20%5C%5C%5C%5C%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_%7Bm1%7D%7D%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_%7Bm2%7D%7D%20%26%20%5C%5Ccdots%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%20f%7D%7B%5C%5Cpartial%20x_%7Bmn%7D%7D%20%5C%5Cend%7Bbmatrix%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fc3f9713908b6cf345958756b44522ae5.svg%22%2C%22id%22%3A%22RaY12%22%7D\&quot;"></card></p>
  <p data-lake-id="\&quot;u57f250eb\&quot;" id="\&quot;u57f250eb\&quot;"><span data-lake-id="\&quot;u4cd85d57\&quot;" id="\&quot;u4cd85d57\&quot;">类似地，</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22f(%5C%5Cmathbf%7Bx%7D)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fd1fed5d79d625df8f8cc788edf0f0328.svg%22%2C%22id%22%3A%22ayRGm%22%7D\&quot;"></card><span data-lake-id="\&quot;u0831c7ea\&quot;" id="\&quot;u0831c7ea\&quot;">的二阶偏导构成的矩阵被称为&quot;黑塞矩阵&quot;（Hessian Matrix）：</span></p>
  <p data-lake-id="\&quot;u368c7434\&quot;" id="\&quot;u368c7434\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22H(f)%20%3D%20%5C%5Cnabla%5E2%20f(%5C%5Cmathbf%7Bx%7D)%20%3D%20%5C%5Cbegin%7Bbmatrix%7D%20%5C%5Cfrac%7B%5C%5Cpartial%5E2%20f%7D%7B%5C%5Cpartial%20x_1%5E2%7D%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%5E2%20f%7D%7B%5C%5Cpartial%20x_1%20%5C%5Cpartial%20x_2%7D%20%26%20%5C%5Ccdots%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%5E2%20f%7D%7B%5C%5Cpartial%20x_1%20%5C%5Cpartial%20x_n%7D%20%5C%5C%5C%5C%20%5C%5Cfrac%7B%5C%5Cpartial%5E2%20f%7D%7B%5C%5Cpartial%20x_2%20%5C%5Cpartial%20x_1%7D%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%5E2%20f%7D%7B%5C%5Cpartial%20x_2%5E2%7D%20%26%20%5C%5Ccdots%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%5E2%20f%7D%7B%5C%5Cpartial%20x_2%20%5C%5Cpartial%20x_n%7D%20%5C%5C%5C%5C%20%5C%5Cvdots%20%26%20%5C%5Cvdots%20%26%20%5C%5Cddots%20%26%20%5C%5Cvdots%20%5C%5C%5C%5C%20%5C%5Cfrac%7B%5C%5Cpartial%5E2%20f%7D%7B%5C%5Cpartial%20x_n%20%5C%5Cpartial%20x_1%7D%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%5E2%20f%7D%7B%5C%5Cpartial%20x_n%20%5C%5Cpartial%20x_2%7D%20%26%20%5C%5Ccdots%20%26%20%5C%5Cfrac%7B%5C%5Cpartial%5E2%20f%7D%7B%5C%5Cpartial%20x_n%5E2%7D%20%5C%5Cend%7Bbmatrix%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fbd45c0620a098333aa1e83c34fd4d6e5.svg%22%2C%22id%22%3A%22HRDt2%22%7D\&quot;"></card></p>
  <p data-lake-id="\&quot;u2a944a1f\&quot;" id="\&quot;u2a944a1f\&quot;"><br /></p>
  <h2 data-lake-id="\&quot;lQVIG\&quot;" id="\&quot;lQVIG\&quot;"><span data-lake-id="\&quot;u6a852743\&quot;" id="\&quot;u6a852743\&quot;">概率论</span></h2>
  <h3 data-lake-id="\&quot;GRqJv\&quot;" id="\&quot;GRqJv\&quot;"><span data-lake-id="\&quot;u9da2302c\&quot;" id="\&quot;u9da2302c\&quot;">概率</span></h3>
  <h4 data-lake-id="\&quot;x7YOB\&quot;" id="\&quot;x7YOB\&quot;"><span data-lake-id="\&quot;u53ef31d0\&quot;" id="\&quot;u53ef31d0\&quot;">概率的概念</span></h4>
  <p data-lake-id="\&quot;u7c0664d4\&quot;" id="\&quot;u7c0664d4\&quot;"><span data-lake-id="\&quot;u03a21295\&quot;" id="\&quot;u03a21295\&quot;">概率是对事件发生的可能性的度量。通常将事件A的概率写作</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F8a147e409c019f76a61a7b43fb904c4d.svg%22%2C%22id%22%3A%22u1b6X%22%7D\&quot;"></card><span data-lake-id="\&quot;udeb328e7\&quot;" id="\&quot;udeb328e7\&quot;">，且</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A)%20%5C%5Cin%20%5B0%2C%201%5D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F0ee03000984075bc1e47ecdca1e1aca2.svg%22%2C%22id%22%3A%22JNx2B%22%7D\&quot;"></card><span data-lake-id="\&quot;u8629c643\&quot;" id="\&quot;u8629c643\&quot;">。</span></p>
  <p data-lake-id="\&quot;u40d86c9a\&quot;" id="\&quot;u40d86c9a\&quot;"><br /></p>
  <h4 data-lake-id="\&quot;enXld\&quot;" id="\&quot;enXld\&quot;"><span data-lake-id="\&quot;u648271c1\&quot;" id="\&quot;u648271c1\&quot;">概率的计算</span></h4>
  <table data-lake-id="\&quot;Kz0Oc\&quot;" id="\&quot;Kz0Oc\&quot;" margin="\&quot;true\&quot;" fit-width="\&quot;true\&quot;" class="\&quot;lake-table\&quot;" style="\&quot;width:" 750px\"="">
   <colgroup>
    <col width="\&quot;375\&quot;" />
    <col width="\&quot;375\&quot;" />
   </colgroup>
   <tbody>
    <tr data-lake-id="\&quot;u7ab3b321\&quot;" id="\&quot;u7ab3b321\&quot;">
     <td data-lake-id="\&quot;ue58bfefa\&quot;" id="\&quot;ue58bfefa\&quot;"><p data-lake-id="\&quot;ub4531609\&quot;" id="\&quot;ub4531609\&quot;"><strong><span data-lake-id="\&quot;uf24c7b16\&quot;" id="\&quot;uf24c7b16\&quot;">事件</span></strong></p></td>
     <td data-lake-id="\&quot;uea633d2d\&quot;" id="\&quot;uea633d2d\&quot;"><p data-lake-id="\&quot;u1086e555\&quot;" id="\&quot;u1086e555\&quot;"><strong><span data-lake-id="\&quot;u357d318d\&quot;" id="\&quot;u357d318d\&quot;">概率</span></strong></p></td>
    </tr>
    <tr data-lake-id="\&quot;uc9ad4bd1\&quot;" id="\&quot;uc9ad4bd1\&quot;">
     <td data-lake-id="\&quot;ue92d637f\&quot;" id="\&quot;ue92d637f\&quot;"><p data-lake-id="\&quot;u504830fa\&quot;" id="\&quot;u504830fa\&quot;"><strong><span data-lake-id="\&quot;uf6421201\&quot;" id="\&quot;uf6421201\&quot;">A</span></strong></p></td>
     <td data-lake-id="\&quot;uc71f8e89\&quot;" id="\&quot;uc71f8e89\&quot;"><p data-lake-id="\&quot;u8f277bf7\&quot;" id="\&quot;u8f277bf7\&quot;">
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A)%20%5C%5Cin%20%5B0%2C%201%5D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F0ee03000984075bc1e47ecdca1e1aca2.svg%22%2C%22id%22%3A%22NolJY%22%7D\&quot;"></card></p></td>
    </tr>
    <tr data-lake-id="\&quot;u9dbd8f96\&quot;" id="\&quot;u9dbd8f96\&quot;">
     <td data-lake-id="\&quot;u07d36367\&quot;" id="\&quot;u07d36367\&quot;"><p data-lake-id="\&quot;ud62e765c\&quot;" id="\&quot;ud62e765c\&quot;"><strong><span data-lake-id="\&quot;uae448e6b\&quot;" id="\&quot;uae448e6b\&quot;">非A</span></strong></p></td>
     <td data-lake-id="\&quot;uc541d53e\&quot;" id="\&quot;uc541d53e\&quot;"><p data-lake-id="\&quot;ua0f40dc9\&quot;" id="\&quot;ua0f40dc9\&quot;">
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(%5C%5Cbar%7BA%7D)%20%3D%201%20-%20P(A)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F95e6d806c7765714a03f15f41d3b2de5.svg%22%2C%22id%22%3A%22xmAOn%22%7D\&quot;"></card></p></td>
    </tr>
    <tr data-lake-id="\&quot;ud1c3996f\&quot;" id="\&quot;ud1c3996f\&quot;">
     <td data-lake-id="\&quot;u5d76a2e6\&quot;" id="\&quot;u5d76a2e6\&quot;"><p data-lake-id="\&quot;u12cde73f\&quot;" id="\&quot;u12cde73f\&quot;"><strong><span data-lake-id="\&quot;u41fb4efd\&quot;" id="\&quot;u41fb4efd\&quot;">A和B</span></strong><span data-lake-id="\&quot;ud6416c1e\&quot;" id="\&quot;ud6416c1e\&quot;">（联合概率）</span></p></td>
     <td data-lake-id="\&quot;u8b3b17ad\&quot;" id="\&quot;u8b3b17ad\&quot;"><p data-lake-id="\&quot;u1a463faf\&quot;" id="\&quot;u1a463faf\&quot;">
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A%20%5C%5Ccap%20B)%20%3D%20P(A%7CB)P(B)%20%3D%20P(B%7CA)P(A)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F5a629abe27f463299530e2d308c72080.svg%22%2C%22id%22%3A%22VUHwb%22%7D\&quot;"></card><span data-lake-id="\&quot;u7f3d9a33\&quot;" id="\&quot;u7f3d9a33\&quot;">；当</span>
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fde951302f41d4707b9d80ca1af34dd0f.svg%22%2C%22id%22%3A%22r4D4q%22%7D\&quot;"></card><span data-lake-id="\&quot;u9c1a0f2c\&quot;" id="\&quot;u9c1a0f2c\&quot;">、</span>
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22B%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F54f5fb1b07a88521e7b036e3bc7a5e33.svg%22%2C%22id%22%3A%22KVBG1%22%7D\&quot;"></card><span data-lake-id="\&quot;ue0edfbc2\&quot;" id="\&quot;ue0edfbc2\&quot;">相互独立时：</span>
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A%20%5C%5Ccap%20B)%20%3D%20P(A)P(B)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fd49b74c3c6422949fc272bcf6687cf47.svg%22%2C%22id%22%3A%22J2pKY%22%7D\&quot;"></card></p></td>
    </tr>
    <tr data-lake-id="\&quot;uc8a514b7\&quot;" id="\&quot;uc8a514b7\&quot;">
     <td data-lake-id="\&quot;u26167bbb\&quot;" id="\&quot;u26167bbb\&quot;"><p data-lake-id="\&quot;u980be80c\&quot;" id="\&quot;u980be80c\&quot;"><strong><span data-lake-id="\&quot;u8ba3cc46\&quot;" id="\&quot;u8ba3cc46\&quot;">A或B</span></strong></p></td>
     <td data-lake-id="\&quot;uc9bba57c\&quot;" id="\&quot;uc9bba57c\&quot;"><p data-lake-id="\&quot;u4839985a\&quot;" id="\&quot;u4839985a\&quot;">
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A%20%5C%5Ccup%20B)%20%3D%20P(A)%20%2B%20P(B)%20-%20P(A%20%5C%5Ccap%20B)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F9e88aecb192bef00449a213e21ee4e02.svg%22%2C%22id%22%3A%22uAD1p%22%7D\&quot;"></card><span data-lake-id="\&quot;u7f00fa64\&quot;" id="\&quot;u7f00fa64\&quot;">；当</span>
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fde951302f41d4707b9d80ca1af34dd0f.svg%22%2C%22id%22%3A%22vxxu8%22%7D\&quot;"></card><span data-lake-id="\&quot;u61022129\&quot;" id="\&quot;u61022129\&quot;">、</span>
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22B%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F54f5fb1b07a88521e7b036e3bc7a5e33.svg%22%2C%22id%22%3A%22t1Rer%22%7D\&quot;"></card><span data-lake-id="\&quot;u326fcd7b\&quot;" id="\&quot;u326fcd7b\&quot;">互斥时：</span>
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A%20%5C%5Ccup%20B)%20%3D%20P(A)%20%2B%20P(B)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F1282e27f337e19d7e36bdadd00c1f9b9.svg%22%2C%22id%22%3A%22JWIYw%22%7D\&quot;"></card></p></td>
    </tr>
    <tr data-lake-id="\&quot;uaebc2213\&quot;" id="\&quot;uaebc2213\&quot;">
     <td data-lake-id="\&quot;u0064f388\&quot;" id="\&quot;u0064f388\&quot;"><p data-lake-id="\&quot;u1400e9b3\&quot;" id="\&quot;u1400e9b3\&quot;"><strong><span data-lake-id="\&quot;u97a58c7e\&quot;" id="\&quot;u97a58c7e\&quot;">B的情况下A的概率</span></strong><span data-lake-id="\&quot;u0d5ceb17\&quot;" id="\&quot;u0d5ceb17\&quot;">（条件概率）</span></p></td>
     <td data-lake-id="\&quot;u7a6204a2\&quot;" id="\&quot;u7a6204a2\&quot;"><p data-lake-id="\&quot;ue2104f15\&quot;" id="\&quot;ue2104f15\&quot;">
       <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A%7CB)%20%3D%20%5C%5Cfrac%7BP(A%20%5C%5Ccap%20B)%7D%7BP(B)%7D%20%3D%20%5C%5Cfrac%7BP(B%7CA)P(A)%7D%7BP(B)%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F2d907b88d141b46fcdef70935f1a377d.svg%22%2C%22id%22%3A%22EiGng%22%7D\&quot;"></card></p></td>
    </tr>
   </tbody>
  </table>
  <p data-lake-id="\&quot;uf38c242b\&quot;" id="\&quot;uf38c242b\&quot;"><span data-lake-id="\&quot;u47706607\&quot;" id="\&quot;u47706607\&quot;">例如：现有一个装有10个球的袋子，其中有6个红球和4个蓝球。从中随机抽取两个球。我们定义以下事件：</span></p>
  <ul list="\&quot;u4d0ac013\&quot;">
   <li fid="\&quot;ub3687569\&quot;" data-lake-id="\&quot;ua28b08db\&quot;" id="\&quot;ua28b08db\&quot;"><span data-lake-id="\&quot;u33d03c09\&quot;" id="\&quot;u33d03c09\&quot;">事件A：第一个抽到的是红球。</span></li>
   <li fid="\&quot;ub3687569\&quot;" data-lake-id="\&quot;u70ead1a7\&quot;" id="\&quot;u70ead1a7\&quot;"><span data-lake-id="\&quot;u67f1694d\&quot;" id="\&quot;u67f1694d\&quot;">事件B：两个抽到的球都是红球。</span></li>
  </ul>
  <ol list="\&quot;u0ba8085f\&quot;">
   <li fid="\&quot;u2862cded\&quot;" data-lake-id="\&quot;ubfc24261\&quot;" id="\&quot;ubfc24261\&quot;"><strong><span data-lake-id="\&quot;u558540f4\&quot;" id="\&quot;u558540f4\&quot;">计算联合概率</span></strong></li>
  </ol>
  <p data-lake-id="\&quot;u7a988aea\&quot;" id="\&quot;u7a988aea\&quot;"><span data-lake-id="\&quot;ue6be1c1f\&quot;" id="\&quot;ue6be1c1f\&quot;">第一个球是红球的概率：</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A)%20%3D%20%5C%5Cfrac%7B6%7D%7B10%7D%20%3D%20%5C%5Cfrac%7B3%7D%7B5%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F1d82905f0d9c1ec69730871064fe7a0b.svg%22%2C%22id%22%3A%22dK18A%22%7D\&quot;"></card></p>
  <p data-lake-id="\&quot;u32ac3d75\&quot;" id="\&quot;u32ac3d75\&quot;"><span data-lake-id="\&quot;u50c45105\&quot;" id="\&quot;u50c45105\&quot;">在第一个球是红球的情况下，两个球都是红球的概率：</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(B%7CA)%20%3D%20%5C%5Cfrac%7B5%7D%7B9%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F39b085a3060023cc67f64a8c6d94c477.svg%22%2C%22id%22%3A%22pheKO%22%7D\&quot;"></card></p>
  <p data-lake-id="\&quot;ubce03839\&quot;" id="\&quot;ubce03839\&quot;"><span data-lake-id="\&quot;ue56f05e5\&quot;" id="\&quot;ue56f05e5\&quot;">联合概率：</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A%20%5C%5Ccap%20B)%20%3D%20P(A)%20%5C%5Ccdot%20P(B%7CA)%20%3D%20%5C%5Cfrac%7B6%7D%7B10%7D%20%5C%5Ccdot%20%5C%5Cfrac%7B5%7D%7B9%7D%20%3D%20%5C%5Cfrac%7B1%7D%7B3%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F5aaf0dafa469aeff01244be79ab6732c.svg%22%2C%22id%22%3A%22KvvVv%22%7D\&quot;"></card></p>
  <ol list="\&quot;udec2452c\&quot;" start="\&quot;2\&quot;">
   <li fid="\&quot;u1d7f8b53\&quot;" data-lake-id="\&quot;u1d46bf06\&quot;" id="\&quot;u1d46bf06\&quot;"><strong><span data-lake-id="\&quot;u55ca17a4\&quot;" id="\&quot;u55ca17a4\&quot;">计算条件概率</span></strong></li>
  </ol>
  <p data-lake-id="\&quot;u5f7618d6\&quot;" id="\&quot;u5f7618d6\&quot;"><span data-lake-id="\&quot;ua91e4361\&quot;" id="\&quot;ua91e4361\&quot;">条件概率</span>
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A%7CB)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F1e28bfe42d1264ff2685ba7221b6d855.svg%22%2C%22id%22%3A%22BB0wO%22%7D\&quot;"></card><span data-lake-id="\&quot;u6a28464b\&quot;" id="\&quot;u6a28464b\&quot;">表示在已知两个球都是红球的情况下，第一个球是红球的概率。</span></p>
  <p data-lake-id="\&quot;ub4c0ee7a\&quot;" id="\&quot;ub4c0ee7a\&quot;"><span data-lake-id="\&quot;u206b77f1\&quot;" id="\&quot;u206b77f1\&quot;">两个球都是红球的概率：</span></p>
  <p data-lake-id="\&quot;ube7edc1a\&quot;" id="\&quot;ube7edc1a\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(B)%20%3D%20%5C%5Cfrac%7BC_6%5E2%7D%7BC_%7B10%7D%5E2%7D%20%3D%20%5C%5Cfrac%7B6%20%5C%5Ctimes%205%20%5C%5Cdiv%202%7D%7B10%20%5C%5Ctimes%209%20%5C%5Cdiv%202%7D%20%3D%20%5C%5Cfrac%7B1%7D%7B3%7D%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F320d8eead30c4964febe391a9219a374.svg%22%2C%22id%22%3A%22pfLey%22%7D\&quot;"></card></p>
  <p data-lake-id="\&quot;u26b121f3\&quot;" id="\&quot;u26b121f3\&quot;"><span data-lake-id="\&quot;u55065d09\&quot;" id="\&quot;u55065d09\&quot;">在两个球都是红球的情况下，第一个球是红球的概率：</span></p>
  <p data-lake-id="\&quot;u3738ec92\&quot;" id="\&quot;u3738ec92\&quot;" style="\&quot;text-align:" center\"="">
   <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A%7CB)%20%3D%20%5C%5Cfrac%7BP(A%20%5C%5Ccap%20B)%7D%7BP(B)%7D%20%3D%20%5C%5Cfrac%7B1%2F3%7D%7B1%2F3%7D%20%3D%201%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F0834f25149df5afa51fb35aecb6a46e6.svg%22%2C%22id%22%3A%22fofqP%22%7D\&quot;"></card></p>
  <blockquote data-lake-id="\&quot;u4e57fca1\&quot;" id="\&quot;u4e57fca1\&quot;" class="\&quot;lake-alert" lake-alert-warning\"="">
   <p data-lake-id="\&quot;u14c42254\&quot;" id="\&quot;u14c42254\&quot;"><strong><span data-lake-id="\&quot;ueafefdda\&quot;" id="\&quot;ueafefdda\&quot;">条件概率公式 </span></strong>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A%7CB)%20%3D%20P(A%20%5C%5Ccap%20B)%20%2F%20P(B)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F5cd9fcd1faaf656e7db5a85da3675f74.svg%22%2C%22id%22%3A%22woX9g%22%7D\&quot;"></card><strong><span data-lake-id="\&quot;ub26aa87a\&quot;" id="\&quot;ub26aa87a\&quot;"> 为什么需要除以 </span></strong>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(B)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fca7ad63a270c2ed124d5b722844376ce.svg%22%2C%22id%22%3A%22ZlLDE%22%7D\&quot;"></card><strong><span data-lake-id="\&quot;u246899c3\&quot;" id="\&quot;u246899c3\&quot;">？</span></strong></p>
   <p data-lake-id="\&quot;ubfe59b2b\&quot;" id="\&quot;ubfe59b2b\&quot;"><span data-lake-id="\&quot;ub3a75684\&quot;" id="\&quot;ub3a75684\&quot;">我们可以从以下几个角度逐步拆解：</span></p>
   <ol list="\&quot;u60e93993\&quot;">
    <li fid="\&quot;ufaf74960\&quot;" data-lake-id="\&quot;u40482c4e\&quot;" id="\&quot;u40482c4e\&quot;"><span data-lake-id="\&quot;uf79424ff\&quot;" id="\&quot;uf79424ff\&quot;">明确条件概率的场景</span></li>
   </ol>
   <p data-lake-id="\&quot;ua4f72b75\&quot;" id="\&quot;ua4f72b75\&quot;"><span data-lake-id="\&quot;u485954d2\&quot;" id="\&quot;u485954d2\&quot;">条件概率 </span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22P(A%7CB)%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F1e28bfe42d1264ff2685ba7221b6d855.svg%22%2C%22id%22%3A%22BWcsG%22%7D\&quot;"></card><span data-lake-id="\&quot;u2879408c\&quot;" id="\&quot;u2879408c\&quot;"> 描述的是「在事件 </span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22B%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F54f5fb1b07a88521e7b036e3bc7a5e33.svg%22%2C%22id%22%3A%22WlNCu%22%7D\&quot;"></card><span data-lake-id="\&quot;u391cb736\&quot;" id="\&quot;u391cb736\&quot;"> 已经发生的条件下，事件 </span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22A%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fde951302f41d4707b9d80ca1af34dd0f.svg%22%2C%22id%22%3A%22Y5PsU%22%7D\&quot;"></card><span data-lake-id="\&quot;uac18c2cd\&quot;" id="\&quot;uac18c2cd\&quot;"> 发生的概率」。关键在于「</span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22B%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F54f5fb1b07a88521e7b036e3bc7a5e33.svg%22%2C%22id%22%3A%22vZg3Y%22%7D\&quot;"></card><span data-lake-id="\&quot;u534ec11c\&quot;" id="\&quot;u534ec11c\&quot;"> 发生」这个条件，它把原来的样本空间 </span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22%5C%5COmega%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fac952fb2338a5acc539486cbdcae059b.svg%22%2C%22id%22%3A%22zWuap%22%7D\&quot;"></card><span data-lake-id="\&quot;u7712e588\&quot;" id="\&quot;u7712e588\&quot;"> 缩小到了只包含事件 </span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22B%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F54f5fb1b07a88521e7b036e3bc7a5e33.svg%22%2C%22id%22%3A%22j0kfW%22%7D\&quot;"></card><span data-lake-id="\&quot;ue04b9342\&quot;" id="\&quot;ue04b9342\&quot;"> 中的结果。</span></p>
   <p data-lake-id="\&quot;u1c3ad196\&quot;" id="\&quot;u1c3ad196\&quot;"><span data-lake-id="\&quot;ub02d91fe\&quot;" id="\&quot;ub02d91fe\&quot;">​</span><br /></p>
   <ol list="\&quot;u81caf9fb\&quot;" start="\&quot;2\&quot;">
    <li fid="\&quot;u4ac72470\&quot;" data-lake-id="\&quot;u38158b9f\&quot;" id="\&quot;u38158b9f\&quot;"><span data-lake-id="\&quot;u8543a5dd\&quot;" id="\&quot;u8543a5dd\&quot;">从频率近似概率的角度理解</span></li>
   </ol>
   <p data-lake-id="\&quot;u6b321ac8\&quot;" id="\&quot;u6b321ac8\&quot;"><span data-lake-id="\&quot;u2d5b6ebc\&quot;" id="\&quot;u2d5b6ebc\&quot;">假设进行了 </span>
    <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22n%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2Fdf378375e7693bdcf9535661c023c02e.svg%22%2C%22id%22%3A%22DBoY6%22%7D\&quot;"></card><span data-lake-id="\&quot;u10753d56\&quot;" id="\&quot;u10753d56\&quot;"> 次重复试验：</span></p>
   <ul list="\&quot;u23679bbd\&quot;">
    <li fid="\&quot;u418bcdff\&quot;" data-lake-id="\&quot;uf89557f1\&quot;" id="\&quot;uf89557f1\&quot;"><span data-lake-id="\&quot;uecc541c8\&quot;" id="\&quot;uecc541c8\&quot;">如果事件 </span>
     <card type="\&quot;inline\&quot;" name="\&quot;math\&quot;" value="\&quot;data:%7B%22code%22%3A%22B%22%2C%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F__latex%2F54f5fb1b07a88521e7b036e3bc7a5e33.svg%22%2C%22id%22%3A%22OHMvg%22%7D\&quot;"></card><span data-lake-id="\&quot;uf2a12335\&quot;" id="\&quot;uf2a12335\&quot;"> 发生了 </span>
