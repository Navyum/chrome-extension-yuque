{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.1.1",
  "description": "__MSG_extDescription__",
  "default_locale": "zh_CN",
  "permissions": [
    "cookies",
    "storage",
    "downloads",
    "declarativeNetRequest",
    "offscreen",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.yuque.com/*",
    "https://cdn.nlark.com/*",
    "https://cdn.yuque.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "src/settings.html",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "__MSG_popupTitle__"
  },
  "content_scripts": [
    {
      "matches": ["https://www.yuque.com/*"],
      "js": ["src/content/bubble.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon-round.png"],
      "matches": ["https://www.yuque.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  }
}
